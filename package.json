{
  "name": "aiimin-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install": "cd frontend && npm install",
    "dev": "npm run dev:api & npm run dev:frontend",
    "dev:api": "node dev_server.js",
    "dev:frontend": "cd frontend && npm start",
    "build": "cd frontend && node scripts/verify-production-env.mjs && npm run build",
    "start": "node dev_server.js",
    "test": "node --test server/services/*.test.js",
    "auth:migrate": "npx @better-auth/cli@latest migrate --config server/lib/auth.js --yes",
    "auth:import-users": "node scripts/migrate-supabase-users-to-better-auth.mjs",
    "auth:backfill-accounts": "node scripts/backfill-better-auth-accounts.mjs",
    "auth:reset-fresh": "node scripts/reset-fresh-start.mjs --confirm"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@hono/node-server": "^2.0.3",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/blob": "^2.4.0",
    "better-auth": "^1.6.23",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "googleapis": "^172.0.0",
    "hono": "^4.12.22",
    "luxon": "^3.7.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "react-helmet-async": "^3.0.0",
    "resend": "^4.8.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  }
}
