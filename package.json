    "test": "node --test server/services/*.test.js"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@hono/node-server": "^2.0.3",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/blob": "^2.4.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "googleapis": "^172.0.0",
    "hono": "^4.12.22",
    "luxon": "^3.7.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  }
}
