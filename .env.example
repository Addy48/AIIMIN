# AIIMIN — root environment (copy to .env — NEVER commit .env)

# ── Database ──
DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# ── Auth (Clerk) ──
CLERK_SECRET_KEY=sk_live_xxx
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# ── Google OAuth (Calendar) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/auth/callback

# ── AI providers (SERVER ONLY — do not use REACT_APP_ prefixes) ──
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# ── Cricket / sports ──
CRICAPI_KEY=
RAPIDAPI_CRICKET_KEY=
RAPIDAPI_CRICKET_HOST=cricket-api-free-data.p.rapidapi.com
CRON_SECRET=

# ── Encryption & storage ──
TOKEN_ENCRYPTION_KEY=
BLOB_READ_WRITE_TOKEN=

# ── Billing (optional) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CORE=
STRIPE_PRICE_PRO=

# ── App ──
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
PORT=3001

# ── One-off scripts only ──
# CREATE_USER_EMAIL=
# CREATE_USER_PASSWORD=
