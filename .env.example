# AIIMIN — root environment (copy to .env — NEVER commit .env)

# ── Database ──
DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# ── Access (waitlist / dev / testers) ──
WAITLIST_MODE=true
DEV_EMAILS=
TESTER_EMAILS=
OWNER_EMAILS=

# ── Better Auth (replaces Supabase Auth for app login) ──
BETTER_AUTH_SECRET=                          # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3001        # prod: https://api.aiimin.in
BETTER_AUTH_API_KEY=                         # from Better Auth Infrastructure dashboard

# ── Google OAuth — LOGIN (Better Auth social provider) ──
GOOGLE_LOGIN_CLIENT_ID=                      # optional; falls back to GOOGLE_CLIENT_ID
GOOGLE_LOGIN_CLIENT_SECRET=

# ── Google OAuth — Calendar/YouTube integration (separate flow; any Gmail account) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_CLIENT_ID=                   # optional override
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://api.aiimin.in/api/google/auth/callback
GOOGLE_REDIRECT_URI=https://api.aiimin.in/api/google/auth/callback

# AI providers (SERVER ONLY — never commit real values; use deploy/EC2.env.paste locally)
GEMINI_LITE_API_KEY=
GEMINI_LITE_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=
GEMINI_DAILY_LIMIT=200
GROQ_API_KEY=
GROQ_DAILY_LIMIT=14400
GROQ_MODEL=llama-3.3-70b-versatile
NVIDIA_API_KEY=
KIMI_API_KEY=
MOONSHOT_DAILY_LIMIT=500
XAI_API_KEY=

# ── Cricket / sports ──
CRICAPI_KEY=
RAPIDAPI_CRICKET_KEY=
RAPIDAPI_CRICKET_HOST=cricket-api-free-data.p.rapidapi.com
CRON_SECRET=

# ── Encryption & storage ──
TOKEN_ENCRYPTION_KEY=
BLOB_READ_WRITE_TOKEN=

# ── Billing (optional) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CORE=
STRIPE_PRICE_PRO=

# ── App ──
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
PORT=3001

# ── Frontend (CRA — also in frontend/.env.local; sync via scripts/sync-react-env.mjs) ──
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_WAITLIST_MODE=true
REACT_APP_DEV_EMAILS=
REACT_APP_TESTER_EMAILS=
# Optional LC-09/10 (create real IDs — do not use G-XXXXXXXXXX placeholder)
REACT_APP_GA_MEASUREMENT_ID=
REACT_APP_SENTRY_DSN=
SENTRY_DSN=

# ─── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@admin.aiimin.in
RESEND_FROM_NAME=AIIMIN
RESEND_REPLY_TO=
# WAITLIST_MEMBER_OFFSET=122
WAITLIST_MEMBER_OFFSET=122
WAITLIST_DISPLAY_CAP=300
RESEND_WAITLIST_TEMPLATE_ID=
