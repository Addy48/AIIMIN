# AIIMIN production environment (example — do not commit secrets)

# ── Waitlist mode ──
REACT_APP_WAITLIST_MODE=true
WAITLIST_MODE=true

# Email allowlist — bypass waitlist + get elite tier
DEV_EMAILS=
TESTER_EMAILS=
OWNER_EMAILS=
REACT_APP_DEV_EMAILS=
REACT_APP_TESTER_EMAILS=

# ── API / database ──
REACT_APP_API_URL=https://api.aiimin.in/api
DATABASE_URL=postgresql://...

# ── Email (AWS SES) ──
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASS=
AWS_SES_REGION=ap-south-1
SES_FROM_EMAIL=noreply@aiimin.in
SES_FROM_NAME=AIIMIN

# ── Cognito (when Phase 2 lands) ──
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# OWNER_COGNITO_SUBS=
