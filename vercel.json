{
    "buildCommand": "npm run build",
    "outputDirectory": "frontend/build",
    "installCommand": "npm install",
    "devCommand": "cd frontend && npm start",
    "framework": "create-react-app",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}