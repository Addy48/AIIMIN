# Local development (automatic)
# `frontend/.env.development` is committed with REACT_APP_WAITLIST_MODE=false so
# `npm start` / `npm run dev` opens the full dashboard without copying env files.
# Optional: copy this file to frontend/.env.local to override any value.

# Waitlist mode — false in .env.development; true in .env.production (Vercel)
REACT_APP_WAITLIST_MODE=false

# Email allowlist bypass (comma-separated, must match server DEV_EMAILS / TESTER_EMAILS)
REACT_APP_DEV_EMAILS=
REACT_APP_TESTER_EMAILS=

# API base — local dev uses Vercel proxy or explicit URL
REACT_APP_API_URL=http://localhost:3001/api

# Supabase anon key only (never service role in frontend)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Optional: Google Analytics 4 (LC-10)
REACT_APP_GA_MEASUREMENT_ID=

# Optional: Sentry browser errors (LC-09)
REACT_APP_SENTRY_DSN=

# AI keys are SERVER-ONLY (GEMINI_API_KEY, GROQ_API_KEY, NVIDIA_API_KEY in root .env).
# Do NOT set REACT_APP_GEMINI_API_KEY or similar — requests go through /api/intelligence/*.
