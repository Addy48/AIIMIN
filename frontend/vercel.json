{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)\\.(.+)$",
            "dest": "/$1.$2"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "env": {
        "REACT_APP_API_URL": "https://api.aiimin.in",
        "REACT_APP_SUPABASE_URL": "https://yubxgftugxbwtywyhcsv.supabase.co",
        "REACT_APP_SUPABASE_ANON_KEY": "sb_publishable_PYSVg1BoYmbBMjndyq-l-w_K_yAKbrB",
        "REACT_APP_GOOGLE_CLIENT_ID": "719779655523-fbio87p15lhshptn8rpeaa779bj41rft.apps.googleusercontent.com"
    }
}