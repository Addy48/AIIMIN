{
  "appId": "in.aiimin.app",
  "appName": "AIIMIN",
  "webDir": "build",
  "app": {
    "appendUserAgent": " AIIMINCapacitor/1.0"
  },
  "server": {
    "url": "https://www.aiimin.in/m",
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "aiimin.in",
      "www.aiimin.in",
      "*.aiimin.in",
      "accounts.google.com",
      "api.aiimin.in"
    ]
  },
  "android": {
    "backgroundColor": "#1A1A1A",
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 400,
      "backgroundColor": "#1A1A1A",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1A1A1A"
    }
  }
}
